<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.meirelesdev.gestao_concreta.controller.ProdutoController">

    <!-- ================================================= -->
    <!-- TÍTULO -->
    <!-- ================================================= -->

    <Label text="Gerenciar Produtos"
           style="-fx-font-size:28px;-fx-font-weight:bold;"
           AnchorPane.topAnchor="20.0"
           AnchorPane.leftAnchor="25.0"/>

    <!-- ================================================= -->
    <!-- FORMULÁRIO -->
    <!-- ================================================= -->

    <VBox spacing="15"
          style="-fx-background-color:white;
                 -fx-background-radius:10;
                 -fx-border-radius:10;
                 -fx-border-color:#DDDDDD;
                 -fx-padding:20;"

          AnchorPane.topAnchor="65.0"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0">

        <!-- PRIMEIRA LINHA -->

        <HBox spacing="20">

            <VBox HBox.hgrow="ALWAYS">

                <Label text="Nome do Produto"/>

                <TextField fx:id="txtNome"
                           maxWidth="1.7976931348623157E308"/>

            </VBox>

            <VBox prefWidth="170">

                <Label text="Preço Compra"/>

                <TextField fx:id="txtPrecoCompra"/>

            </VBox>

            <VBox prefWidth="170">

                <Label text="Preço Venda"/>

                <TextField fx:id="txtPrecoVenda"/>

            </VBox>

        </HBox>

        <!-- SEGUNDA LINHA -->

        <HBox spacing="20">

            <VBox prefWidth="220">

                <Label text="Quantidade Inicial"/>

                <TextField fx:id="txtQuantidadeInicial"/>

            </VBox>

            <VBox prefWidth="220">

                <Label text="Estoque Mínimo"/>

                <TextField fx:id="txtEstoqueMinimo"/>

            </VBox>

            <Pane HBox.hgrow="ALWAYS"/>

            <Button fx:id="btnSalvar"
                    prefWidth="120"
                    prefHeight="38"
                    text="Salvar"
                    style="-fx-background-color:#19B5A5;
                           -fx-text-fill:white;
                           -fx-font-weight:bold;"/>

            <Button fx:id="btnLimpar"
                    prefWidth="120"
                    prefHeight="38"
                    text="Limpar"/>

        </HBox>

    </VBox>

    <!-- ================================================= -->
    <!-- PESQUISA -->
    <!-- ================================================= -->

    <Label text="Pesquisar Produto"
           style="-fx-font-size:15px;-fx-font-weight:bold;"
           AnchorPane.topAnchor="315.0"
           AnchorPane.leftAnchor="20.0"/>

    <HBox spacing="15"
          alignment="CENTER_LEFT"
          AnchorPane.topAnchor="340.0"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0">

        <TextField fx:id="txtPesquisar"
                   promptText="Digite o nome ou código do produto"
                   HBox.hgrow="ALWAYS"/>

        <Button fx:id="btnPesquisar"
                prefWidth="130"
                prefHeight="35"
                text="Pesquisar"
                style="-fx-background-color:#19B5A5;
                       -fx-text-fill:white;
                       -fx-font-weight:bold;"/>

        <Pane HBox.hgrow="ALWAYS"/>

        <!-- CARD PRODUTOS -->

        <VBox alignment="CENTER"
              spacing="5"
              prefWidth="120"
              prefHeight="70"
              style="-fx-background-color:#19B5A5;
                     -fx-background-radius:10;">

            <Label text="Produtos"
                   style="-fx-text-fill:white;"/>

            <Label fx:id="lblProdutos"
                   text="0"
                   style="-fx-font-size:22px;
                          -fx-font-weight:bold;
                          -fx-text-fill:white;"/>

        </VBox>

        <!-- CARD ALERTA -->

        <VBox alignment="CENTER"
              spacing="5"
              prefWidth="120"
              prefHeight="70"
              style="-fx-background-color:#FF6933;
                     -fx-background-radius:10;">

            <Label text="Alerta"
                   style="-fx-text-fill:white;"/>

            <Label fx:id="lblAlerta"
                   text="0"
                   style="-fx-font-size:22px;
                          -fx-font-weight:bold;
                          -fx-text-fill:white;"/>

        </VBox>

        <!-- CARD ESGOTADOS -->

        <VBox alignment="CENTER"
              spacing="5"
              prefWidth="120"
              prefHeight="70"
              style="-fx-background-color:#FF0048;
                     -fx-background-radius:10;">

            <Label text="Esgot."
                   style="-fx-text-fill:white;"/>

            <Label fx:id="lblEsgotados"
                   text="0"
                   style="-fx-font-size:22px;
                          -fx-font-weight:bold;
                          -fx-text-fill:white;"/>

        </VBox>

    </HBox>

    <!-- ================================================= -->
    <!-- TABELA -->
    <!-- ================================================= -->

    <TableView fx:id="tableProdutos"
               AnchorPane.topAnchor="410.0"
               AnchorPane.leftAnchor="20.0"
               AnchorPane.rightAnchor="20.0"
               AnchorPane.bottomAnchor="70.0">

        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>

        <columns>

            <TableColumn fx:id="colCodigo"
                         text="Código"
                         prefWidth="80"/>

            <TableColumn fx:id="colNome"
                         text="Produto"
                         prefWidth="300"/>

            <TableColumn fx:id="colCompra"
                         text="Compra"
                         prefWidth="120"/>

            <TableColumn fx:id="colVenda"
                         text="Venda"
                         prefWidth="120"/>

            <TableColumn fx:id="colEstoque"
                         text="Estoque"
                         prefWidth="100"/>

            <TableColumn fx:id="colMinimo"
                         text="Mínimo"
                         prefWidth="100"/>

            <TableColumn fx:id="colStatus"
                         text="Status"
                         prefWidth="180"/>

        </columns>

    </TableView>

    <!-- ================================================= -->
    <!-- BOTÕES -->
    <!-- ================================================= -->

    <HBox spacing="15"
          alignment="CENTER_LEFT"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0"
          AnchorPane.bottomAnchor="20.0">

        <Button fx:id="btnEditar"
                prefWidth="170"
                prefHeight="38"
                text="Editar Produto"
                style="-fx-background-color:#EDE89D;
                       -fx-font-weight:bold;"/>

        <Button fx:id="btnEntradaEstoque"
                prefWidth="190"
                prefHeight="38"
                text="Entrada Estoque"
                style="-fx-background-color:#19B5A5;
                       -fx-text-fill:white;
                       -fx-font-weight:bold;"/>

        <Button fx:id="btnRemover"
                prefWidth="180"
                prefHeight="38"
                text="Remover Produto"
                style="-fx-background-color:#FF0048;
                       -fx-text-fill:white;
                       -fx-font-weight:bold;"/>

        <!-- Espaço para empurrar os botões para a esquerda -->

        <Pane HBox.hgrow="ALWAYS"/>

    </HBox>

</AnchorPane>