<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefWidth="1280"
            prefHeight="720"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.meirelesdev.gestao_concreta.controller.TelaPrincipalController">

    <!-- ================================================= -->
    <!-- SIDEBAR -->
    <!-- ================================================= -->

    <VBox prefWidth="250"
          minWidth="250"
          maxWidth="250"
          spacing="10"
          style="-fx-background-color:#5E5473;"

          AnchorPane.leftAnchor="0.0"
          AnchorPane.topAnchor="0.0"
          AnchorPane.bottomAnchor="0.0">

        <padding>
            <Insets top="25" right="20" bottom="20" left="20"/>
        </padding>

        <!-- Logo -->

        <Label text="Gestão Concreta"
               style="-fx-text-fill:white;
                      -fx-font-size:24px;
                      -fx-font-weight:bold;"/>

        <Label text="Sistema de Gestão"
               style="-fx-text-fill:#D9D9D9;
                      -fx-font-size:12px;"/>

        <Region prefHeight="25"/>

        <!-- MENU -->

        <Button fx:id="btnInicio"
                prefHeight="42"
                maxWidth="1.7976931348623157E308"
                text="🏠 Início"
                onAction="#abrirInicio"/>

        <Button fx:id="btnProdutos"
                prefHeight="42"
                maxWidth="1.7976931348623157E308"
                text="📦 Produtos"
                onAction="#abrirProdutos"/>

        <Button fx:id="btnVendas"
                prefHeight="42"
                maxWidth="1.7976931348623157E308"
                text="💰 Vendas"
                onAction="#abrirVendas"/>

        <Button fx:id="btnRelatorios"
                prefHeight="42"
                maxWidth="1.7976931348623157E308"
                text="📊 Relatórios"
                onAction="#abrirRelatorios"/>

        <Button fx:id="btnConfiguracoes"
                prefHeight="42"
                maxWidth="1.7976931348623157E308"
                text="⚙ Configurações"
                onAction="#abrirConfiguracoes"/>

        <!-- Empurra o usuário para baixo -->

        <Pane VBox.vgrow="ALWAYS"/>

        <!-- Usuário -->

        <Label text="Usuário"
               style="-fx-text-fill:white;
                      -fx-font-weight:bold;"/>

        <Label fx:id="lblUsuario"
               text="Administrador"
               style="-fx-text-fill:white;"/>

        <Label text="Perfil"
               style="-fx-text-fill:white;
                      -fx-font-weight:bold;"/>

        <Label fx:id="lblPerfil"
               text="Administrador"
               style="-fx-text-fill:white;"/>

        <Region prefHeight="10"/>

        <Button fx:id="btnSair"
                prefHeight="35"
                maxWidth="1.7976931348623157E308"
                text="🚪 Sair"
                onAction="#sairSistema"
                style="-fx-background-color:#FF0048;
                       -fx-text-fill:white;
                       -fx-font-weight:bold;"/>

    </VBox>

    <!-- ================================================= -->
    <!-- CONTEÚDO -->
    <!-- ================================================= -->

    <AnchorPane fx:id="painelConteudo"
                style="-fx-background-color:#F7F7F7;"
                AnchorPane.leftAnchor="250.0"
                AnchorPane.rightAnchor="0.0"
                AnchorPane.topAnchor="0.0"
                AnchorPane.bottomAnchor="0.0"/>

</AnchorPane>