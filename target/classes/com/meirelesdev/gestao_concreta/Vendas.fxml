<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.meirelesdev.gestao_concreta.controller.VendaController">

    <!-- ================================================= -->
    <!-- TÍTULO -->
    <!-- ================================================= -->

    <Label text="Registrar Venda"
           style="-fx-font-size:28px;-fx-font-weight:bold;"
           AnchorPane.topAnchor="20.0"
           AnchorPane.leftAnchor="25.0"/>

    <!-- ================================================= -->
    <!-- PESQUISA -->
    <!-- ================================================= -->

    <Label text="Pesquisar Produto"
           style="-fx-font-size:15px;-fx-font-weight:bold;"
           AnchorPane.topAnchor="65.0"
           AnchorPane.leftAnchor="20.0"/>

    <HBox spacing="15"
          alignment="CENTER_LEFT"
          AnchorPane.topAnchor="92.0"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0">

        <TextField fx:id="txtPesquisar"
                   promptText="Digite o nome ou código do produto"
                   HBox.hgrow="ALWAYS"/>

        <Button fx:id="btnPesquisar"
                prefWidth="130"
                prefHeight="35"
                text="Pesquisar"
                style="-fx-background-color:#19B5A5;
                       -fx-text-fill:white;
                       -fx-font-weight:bold;"/>

    </HBox>

    <!-- ================================================= -->
    <!-- PRODUTOS DISPONÍVEIS -->
    <!-- ================================================= -->

    <Label text="Produtos Disponíveis"
           style="-fx-font-size:15px;-fx-font-weight:bold;"
           AnchorPane.topAnchor="145.0"
           AnchorPane.leftAnchor="20.0"/>

    <TableView fx:id="tableProdutos"
               AnchorPane.topAnchor="172.0"
               AnchorPane.leftAnchor="20.0"
               AnchorPane.rightAnchor="20.0"
               prefHeight="190">

        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>

        <columns>

            <TableColumn fx:id="colCodigo"
                         text="Código"
                         prefWidth="80"/>

            <TableColumn fx:id="colNome"
                         text="Produto"
                         prefWidth="400"/>

            <TableColumn fx:id="colPreco"
                         text="Preço"
                         prefWidth="140"/>

            <TableColumn fx:id="colEstoque"
                         text="Estoque"
                         prefWidth="120"/>

            <TableColumn fx:id="colStatus"
                         text="Status"
                         prefWidth="250"/>

        </columns>

    </TableView>

    <!-- ================================================= -->
    <!-- ADICIONAR ITEM -->
    <!-- ================================================= -->

    <VBox spacing="15"
          style="-fx-background-color:white;
                 -fx-border-color:#DDDDDD;
                 -fx-background-radius:10;
                 -fx-border-radius:10;
                 -fx-padding:20;"

          AnchorPane.topAnchor="380.0"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0">

        <Label text="Adicionar Item"
               style="-fx-font-size:15px;
                      -fx-font-weight:bold;"/>

        <HBox spacing="20"
              alignment="CENTER_LEFT">

            <!-- Produto -->

            <VBox HBox.hgrow="ALWAYS">

                <Label text="Produto Selecionado"/>

                <Label fx:id="lblProdutoSelecionado"
                       text="Nenhum produto selecionado"
                       maxWidth="1.7976931348623157E308"
                       style="-fx-background-color:#F4F4F4;
                              -fx-border-color:#CCCCCC;
                              -fx-background-radius:5;
                              -fx-border-radius:5;
                              -fx-padding:8;
                              -fx-font-weight:bold;"/>

            </VBox>

            <!-- Quantidade -->

            <VBox prefWidth="140">

                <Label text="Quantidade"/>

                <TextField fx:id="txtQuantidade"/>

            </VBox>

            <!-- Botão -->

            <Button fx:id="btnAdicionar"
                    prefWidth="170"
                    prefHeight="36"
                    text="Adicionar Item"
                    style="-fx-background-color:#19B5A5;
                           -fx-text-fill:white;
                           -fx-font-weight:bold;"/>

        </HBox>

    </VBox>

    <!-- ================================================= -->
    <!-- ITENS DA VENDA -->
    <!-- ================================================= -->

    <Label text="Itens da Venda"
           style="-fx-font-size:15px;-fx-font-weight:bold;"
           AnchorPane.topAnchor="495.0"
           AnchorPane.leftAnchor="20.0"/>

    <HBox spacing="20"
          AnchorPane.topAnchor="522.0"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0"
          AnchorPane.bottomAnchor="70.0">

        <!-- =========================================== -->
        <!-- TABELA -->
        <!-- =========================================== -->

        <TableView fx:id="tableItensVenda"
                   HBox.hgrow="ALWAYS">

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>

            <columns>

                <TableColumn fx:id="colProdutoVenda"
                             text="Produto"
                             prefWidth="320"/>

                <TableColumn fx:id="colQtdVenda"
                             text="Qtd."
                             prefWidth="90"/>

                <TableColumn fx:id="colValorUnitario"
                             text="Valor Unit."
                             prefWidth="140"/>

                <TableColumn fx:id="colSubtotal"
                             text="Subtotal"
                             prefWidth="160"/>

            </columns>

        </TableView>

        <!-- =========================================== -->
        <!-- RESUMO -->
        <!-- =========================================== -->

        <VBox spacing="15"
              alignment="CENTER"
              prefWidth="260"
              style="-fx-background-color:white;
                     -fx-border-color:#DDDDDD;
                     -fx-background-radius:10;
                     -fx-border-radius:10;
                     -fx-padding:20;">

            <Label text="Valor Total"
                   style="-fx-font-size:17px;
                          -fx-font-weight:bold;"/>

            <Label fx:id="lblValorTotal"
                   text="R$ 0,00"
                   style="-fx-font-size:34px;
                          -fx-font-weight:bold;
                          -fx-text-fill:#19B5A5;"/>

        </VBox>

    </HBox>

    <!-- ================================================= -->
    <!-- FINALIZAÇÃO -->
    <!-- ================================================= -->

    <HBox spacing="15"
          alignment="CENTER_LEFT"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0"
          AnchorPane.bottomAnchor="20.0">

        <Label text="Forma de Pagamento"/>

        <ComboBox fx:id="cbPagamento"
                  prefWidth="180"/>

        <Label text="Data"/>

        <DatePicker fx:id="dpDataVenda"
                    prefWidth="160"/>

        <Pane HBox.hgrow="ALWAYS"/>

        <Button fx:id="btnRemoverItem"
                prefWidth="150"
                prefHeight="38"
                text="Remover Item"
                style="-fx-background-color:#FF6933;
                       -fx-text-fill:white;
                       -fx-font-weight:bold;"/>

        <Button fx:id="btnLimpar"
                prefWidth="100"
                prefHeight="38"
                text="Limpar"/>

        <Button fx:id="btnRegistrarVenda"
                prefWidth="120"
                prefHeight="38"
                text="Registrar"
                style="-fx-background-color:#19B5A5;
                       -fx-text-fill:white;
                       -fx-font-weight:bold;"/>

    </HBox>

</AnchorPane>