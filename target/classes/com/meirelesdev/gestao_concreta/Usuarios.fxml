<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.meirelesdev.gestao_concreta.controller.UsuarioController">

    <!-- ================================================= -->
    <!-- TÍTULO -->
    <!-- ================================================= -->

    <Label text="Gerenciar Usuários"
           style="-fx-font-size:28px;
                  -fx-font-weight:bold;"
           AnchorPane.topAnchor="20.0"
           AnchorPane.leftAnchor="25.0"/>

    <!-- ================================================= -->
    <!-- FORMULÁRIO -->
    <!-- ================================================= -->

    <VBox spacing="18"
          style="-fx-background-color:white;
                 -fx-background-radius:10;
                 -fx-border-radius:10;
                 -fx-border-color:#DDDDDD;
                 -fx-padding:20;"

          AnchorPane.topAnchor="65.0"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0">

        <!-- PRIMEIRA LINHA -->

        <HBox spacing="20">

            <VBox HBox.hgrow="ALWAYS">

                <Label text="Nome"/>

                <TextField fx:id="txtNome"
                           maxWidth="1.7976931348623157E308"
                           promptText="Nome do usuário"/>

            </VBox>

            <VBox HBox.hgrow="ALWAYS">

                <Label text="Login"/>

                <TextField fx:id="txtLogin"
                           maxWidth="1.7976931348623157E308"
                           promptText="Login"/>

            </VBox>

        </HBox>

        <!-- SEGUNDA LINHA -->

        <HBox spacing="20">

            <VBox HBox.hgrow="ALWAYS">

                <Label text="Senha"/>

                <PasswordField fx:id="txtSenha"
                               maxWidth="1.7976931348623157E308"
                               promptText="Senha"/>

            </VBox>

            <VBox HBox.hgrow="ALWAYS">

                <Label text="Perfil"/>

                <ComboBox fx:id="cbPerfil"
                          maxWidth="1.7976931348623157E308"
                          promptText="Selecione"/>

            </VBox>

        </HBox>

        <!-- BOTÕES -->

        <HBox spacing="15">

            <Region HBox.hgrow="ALWAYS"/>

            <Button fx:id="btnSalvar"
                    prefWidth="120"
                    prefHeight="38"
                    text="Salvar"
                    style="-fx-background-color:#19B5A5;
                           -fx-text-fill:white;
                           -fx-font-weight:bold;"/>

            <Button fx:id="btnLimpar"
                    prefWidth="120"
                    prefHeight="38"
                    text="Limpar"/>

        </HBox>

    </VBox>

    <!-- ================================================= -->
    <!-- PESQUISA -->
    <!-- ================================================= -->

    <Label text="Pesquisar Usuário"
           style="-fx-font-size:15px;
                  -fx-font-weight:bold;"
           AnchorPane.topAnchor="300.0"
           AnchorPane.leftAnchor="20.0"/>

    <HBox spacing="15"
          AnchorPane.topAnchor="330.0"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0">

        <TextField fx:id="txtPesquisar"
                   HBox.hgrow="ALWAYS"
                   promptText="Digite o nome ou login do usuário"/>

        <Button fx:id="btnPesquisar"
                prefWidth="130"
                prefHeight="35"
                text="Pesquisar"
                style="-fx-background-color:#19B5A5;
                       -fx-text-fill:white;
                       -fx-font-weight:bold;"/>

    </HBox>

    <!-- ================================================= -->
    <!-- CARDS -->
    <!-- ================================================= -->

    <HBox spacing="20"
          AnchorPane.topAnchor="380.0"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0">

        <!-- Total -->

        <VBox spacing="10"
              prefWidth="180"
              style="-fx-background-color:#19B5A5;
                     -fx-background-radius:10;
                     -fx-padding:15;">

            <Label text="Usuários"
                   style="-fx-text-fill:white;"/>

            <Label fx:id="lblUsuarios"
                   text="0"
                   style="-fx-font-size:24px;
                          -fx-font-weight:bold;
                          -fx-text-fill:white;"/>

        </VBox>

        <!-- Administradores -->

        <VBox spacing="10"
              prefWidth="180"
              style="-fx-background-color:#5E5473;
                     -fx-background-radius:10;
                     -fx-padding:15;">

            <Label text="Administradores"
                   style="-fx-text-fill:white;"/>

            <Label fx:id="lblAdministradores"
                   text="0"
                   style="-fx-font-size:24px;
                          -fx-font-weight:bold;
                          -fx-text-fill:white;"/>

        </VBox>

        <!-- Funcionários -->

        <VBox spacing="10"
              prefWidth="180"
              style="-fx-background-color:#FF6933;
                     -fx-background-radius:10;
                     -fx-padding:15;">

            <Label text="Funcionários"
                   style="-fx-text-fill:white;"/>

            <Label fx:id="lblFuncionarios"
                   text="0"
                   style="-fx-font-size:24px;
                          -fx-font-weight:bold;
                          -fx-text-fill:white;"/>

        </VBox>

    </HBox>

    <!-- ================================================= -->
    <!-- TABELA -->
    <!-- ================================================= -->

    <TableView fx:id="tableUsuarios"
               AnchorPane.topAnchor="470.0"
               AnchorPane.leftAnchor="20.0"
               AnchorPane.rightAnchor="20.0"
               AnchorPane.bottomAnchor="70.0">

        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>

        <columns>

            <TableColumn fx:id="colCodigo"
                         text="Código"
                         maxWidth="90"/>

            <TableColumn fx:id="colNome"
                         text="Nome"/>

            <TableColumn fx:id="colLogin"
                         text="Login"/>

            <TableColumn fx:id="colPerfil"
                         text="Perfil"
                         maxWidth="170"/>

        </columns>

    </TableView>

    <!-- ================================================= -->
    <!-- BOTÕES -->
    <!-- ================================================= -->

    <HBox spacing="15"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.bottomAnchor="20.0">

        <Button fx:id="btnEditar"
                prefWidth="170"
                prefHeight="38"
                text="Editar Usuário"
                style="-fx-background-color:#EDE89D;
                       -fx-font-weight:bold;"/>

        <Button fx:id="btnRemover"
                prefWidth="180"
                prefHeight="38"
                text="Remover Usuário"
                style="-fx-background-color:#FF0048;
                       -fx-text-fill:white;
                       -fx-font-weight:bold;"/>

    </HBox>

</AnchorPane>