<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.meirelesdev.gestao_concreta.controller.InicioController">

    <!-- ================================================= -->
    <!-- TÍTULO -->
    <!-- ================================================= -->

    <Label text="Dashboard"
           style="-fx-font-size:30px;
                  -fx-font-weight:bold;"
           AnchorPane.topAnchor="20.0"
           AnchorPane.leftAnchor="25.0"/>

    <!-- ================================================= -->
    <!-- CARDS -->
    <!-- ================================================= -->

    <HBox spacing="15"
          AnchorPane.topAnchor="75.0"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0">

        <!-- Produtos -->

        <VBox spacing="10"
              prefHeight="110"
              HBox.hgrow="ALWAYS"
              style="-fx-background-color:#19B5A5;
                     -fx-background-radius:10;
                     -fx-padding:20;">

            <Label text="Produtos"
                   style="-fx-text-fill:white;
                          -fx-font-size:16px;"/>

            <Label fx:id="lblProdutos"
                   text="0"
                   style="-fx-text-fill:white;
                          -fx-font-size:34px;
                          -fx-font-weight:bold;"/>

        </VBox>

        <!-- Vendas -->

        <VBox spacing="10"
              prefHeight="110"
              HBox.hgrow="ALWAYS"
              style="-fx-background-color:#5E5473;
                     -fx-background-radius:10;
                     -fx-padding:20;">

            <Label text="Vendas"
                   style="-fx-text-fill:white;
                          -fx-font-size:16px;"/>

            <Label fx:id="lblVendas"
                   text="0"
                   style="-fx-text-fill:white;
                          -fx-font-size:34px;
                          -fx-font-weight:bold;"/>

        </VBox>

        <!-- Faturamento -->

        <VBox spacing="10"
              prefHeight="110"
              HBox.hgrow="ALWAYS"
              style="-fx-background-color:#FF6933;
                     -fx-background-radius:10;
                     -fx-padding:20;">

            <Label text="Faturamento"
                   style="-fx-text-fill:white;
                          -fx-font-size:16px;"/>

            <Label fx:id="lblFaturamento"
                   text="R$ 0,00"
                   style="-fx-text-fill:white;
                          -fx-font-size:28px;
                          -fx-font-weight:bold;"/>

        </VBox>

        <!-- Estoque -->

        <VBox spacing="10"
              prefHeight="110"
              HBox.hgrow="ALWAYS"
              style="-fx-background-color:#FF0048;
                     -fx-background-radius:10;
                     -fx-padding:20;">

            <Label text="Estoque Baixo"
                   style="-fx-text-fill:white;
                          -fx-font-size:16px;"/>

            <Label fx:id="lblEstoque"
                   text="0"
                   style="-fx-text-fill:white;
                          -fx-font-size:34px;
                          -fx-font-weight:bold;"/>

        </VBox>

    </HBox>

    <!-- ================================================= -->
    <!-- GRÁFICO + TABELA -->
    <!-- ================================================= -->

    <HBox spacing="20"
          AnchorPane.topAnchor="215.0"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0"
          AnchorPane.bottomAnchor="20.0">

        <!-- ============================================== -->
        <!-- GRÁFICO -->
        <!-- ============================================== -->

        <LineChart fx:id="lineChart"
                   HBox.hgrow="ALWAYS"
                   title="Vendas dos Últimos Meses">

            <xAxis>
                <CategoryAxis fx:id="xLine"/>
            </xAxis>

            <yAxis>
                <NumberAxis fx:id="yLine"/>
            </yAxis>

        </LineChart>

        <!-- ============================================== -->
        <!-- PAINEL ESTOQUE BAIXO -->
        <!-- ============================================== -->

        <VBox spacing="15"
              prefWidth="340"
              style="-fx-background-color:white;
                     -fx-background-radius:10;
                     -fx-border-color:#DDDDDD;
                     -fx-border-radius:10;
                     -fx-padding:15;">

            <Label text="Produtos com Estoque Baixo"
                   style="-fx-font-size:18px;
                          -fx-font-weight:bold;"/>

            <TableView fx:id="tableEstoque"
                       VBox.vgrow="ALWAYS">

                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>

                <columns>

                    <TableColumn fx:id="colProduto"
                                 text="Produto"
                                 prefWidth="180"/>

                    <TableColumn fx:id="colQtd"
                                 text="Qtd."
                                 prefWidth="60"/>

                    <TableColumn fx:id="colMinimo"
                                 text="Mín."
                                 prefWidth="70"/>

                </columns>

            </TableView>

        </VBox>

    </HBox>

</AnchorPane>